# Photon / iMessage (see Photon SDK docs)
RECALL_TRIGGER=recall
MAX_MESSAGES=100

# Optional: after fetching history, POST transcript to local Second Brain API
# (run `npm run dev` at repo root so Express is on :3001)
SECOND_BRAIN_INGEST_ON_RECALL=true
SECOND_BRAIN_API_URL=http://localhost:3001
SECOND_BRAIN_USER_ID=
